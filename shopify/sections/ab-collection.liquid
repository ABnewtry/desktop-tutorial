{%- comment -%}
  ════════════════════════════════════════════════
  AB — قسم المجموعة (Poster Hero متحرك + شبكة منتجات بانيميشن)
  يصلح للكولكشنات الثلاثة: travel / anime / couples
  التركيب: Online Store → Themes → Edit code → Sections → Add a new section
  سمّه: ab-collection  ثم الصق هذا واحفظ.
  الاستخدام: في صفحة المجموعة Customize → Add section → AB — المجموعة
  - يقرأ تلقائياً منتجات المجموعة الحالية (collection.products)
  - البوستر: يأخذ صورة المجموعة، وإن لم توجد يعرض بليس هولدر متحرك
  ════════════════════════════════════════════════
{%- endcomment -%}

<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;500;600;700;900&display=swap" rel="stylesheet">

{%- assign accent = section.settings.accent | default: '#AAFF00' -%}

<style>
  #ab-col-{{ section.id }}{
    --ab-black:#080808; --ab-neon:{{ accent }}; --ab-silver:#9a9a9a;
    --ab-white:#F0F0F0; --ab-border:#222;
    background:var(--ab-black); color:var(--ab-white);
    font-family:'Cairo',sans-serif; direction:rtl;
    margin:0; padding:0; overflow:hidden;
  }
  #ab-col-{{ section.id }} *{box-sizing:border-box}

  /* ===== POSTER HERO ===== */
  #ab-col-{{ section.id }} .abc-hero{
    position:relative; min-height:70vh; display:flex;
    align-items:flex-end; overflow:hidden;
  }
  #ab-col-{{ section.id }} .abc-poster{
    position:absolute; inset:0; z-index:0;
    background-size:cover; background-position:center;
    animation:abc-kb 18s ease-in-out infinite alternate;
  }
  @keyframes abc-kb{from{transform:scale(1) translateY(0)}to{transform:scale(1.12) translateY(-2%)}}
  /* بليس هولدر متحرك إن لم توجد صورة */
  #ab-col-{{ section.id }} .abc-ph{
    position:absolute; inset:0; z-index:0;
    background:
      radial-gradient(circle at 30% 30%, rgba(170,255,0,.10), transparent 55%),
      repeating-linear-gradient(45deg,#0d0d0d 0 22px,#0a0a0a 22px 44px);
    animation:abc-kb 18s ease-in-out infinite alternate;
  }
  #ab-col-{{ section.id }} .abc-ph::after{
    content:'POSTER'; position:absolute; inset:0; display:flex;
    align-items:center; justify-content:center;
    font-size:clamp(2rem,8vw,5rem); font-weight:900; letter-spacing:.3em;
    color:rgba(255,255,255,.05);
  }
  #ab-col-{{ section.id }} .abc-scrim{
    position:absolute; inset:0; z-index:1;
    background:linear-gradient(to top,var(--ab-black) 4%,rgba(8,8,8,.55) 45%,rgba(8,8,8,.15) 100%);
  }
  #ab-col-{{ section.id }} .abc-hero-in{
    position:relative; z-index:2; padding:0 6vw 6vh; width:100%;
  }
  #ab-col-{{ section.id }} .abc-tag{
    display:inline-block; font-size:.66rem; font-weight:700; letter-spacing:.3em;
    color:#000; background:var(--ab-neon); padding:.4rem 1rem; margin-bottom:1.1rem;
    clip-path:polygon(6px 0,100% 0,calc(100% - 6px) 100%,0 100%);
    animation:abc-up .9s .1s both;
  }
  #ab-col-{{ section.id }} .abc-title{
    font-size:clamp(2.6rem,11vw,6rem); font-weight:900; line-height:.95; margin:0;
    animation:abc-up 1s .2s both;
  }
  #ab-col-{{ section.id }} .abc-sub{
    font-size:clamp(1rem,3.4vw,1.4rem); font-weight:300; color:var(--ab-silver);
    max-width:560px; margin:.9rem 0 0; animation:abc-up 1s .35s both;
  }
  #ab-col-{{ section.id }} .abc-under{
    height:3px; width:0; background:var(--ab-neon); margin-top:1.4rem;
    animation:abc-grow 1s 1s forwards;
  }
  @keyframes abc-grow{to{width:120px}}
  @keyframes abc-up{from{opacity:0;transform:translateY(26px)}to{opacity:1;transform:none}}

  /* ===== GRID ===== */
  #ab-col-{{ section.id }} .abc-grid{
    display:grid; grid-template-columns:repeat(2,1fr); gap:14px;
    padding:8vh 5vw; max-width:1200px; margin:0 auto;
  }
  @media(min-width:900px){#ab-col-{{ section.id }} .abc-grid{grid-template-columns:repeat(3,1fr); gap:22px}}

  #ab-col-{{ section.id }} .abc-card{
    position:relative; background:#0d0d0d; border:1px solid var(--ab-border);
    text-decoration:none; color:inherit; overflow:hidden;
    opacity:0; transform:translateY(40px); transition:opacity .7s, transform .7s, border-color .25s;
  }
  #ab-col-{{ section.id }} .abc-card.shown{opacity:1; transform:none}
  #ab-col-{{ section.id }} .abc-card:hover{border-color:var(--ab-neon)}
  #ab-col-{{ section.id }} .abc-media{
    position:relative; aspect-ratio:4/5; overflow:hidden; background:#111;
  }
  #ab-col-{{ section.id }} .abc-media img{
    width:100%; height:100%; object-fit:cover; transition:transform .6s ease;
  }
  #ab-col-{{ section.id }} .abc-card:hover .abc-media img{transform:scale(1.06)}
  #ab-col-{{ section.id }} .abc-media .abc-noimg{
    position:absolute; inset:0; display:flex; align-items:center; justify-content:center;
    color:#333; font-weight:900; font-size:2rem; letter-spacing:.2em;
    background:repeating-linear-gradient(45deg,#101010 0 18px,#0d0d0d 18px 36px);
  }
  #ab-col-{{ section.id }} .abc-soon{
    position:absolute; top:10px; inset-inline-start:10px; z-index:2;
    font-size:.6rem; font-weight:700; letter-spacing:.18em; color:#000;
    background:var(--ab-neon); padding:.28rem .7rem;
  }
  #ab-col-{{ section.id }} .abc-info{padding:.95rem 1rem 1.2rem}
  #ab-col-{{ section.id }} .abc-name{font-size:.92rem; font-weight:600; margin:0 0 .35rem; line-height:1.3}
  #ab-col-{{ section.id }} .abc-price{font-size:.85rem; font-weight:700; color:var(--ab-neon)}
  #ab-col-{{ section.id }} .abc-cmp{color:#666; text-decoration:line-through; font-weight:400; margin-inline-start:.5rem; font-size:.78rem}

  #ab-col-{{ section.id }} .abc-empty{
    text-align:center; padding:14vh 6vw; color:var(--ab-silver);
  }
  #ab-col-{{ section.id }} .abc-empty b{color:var(--ab-neon)}
</style>

<div id="ab-col-{{ section.id }}">

  <!-- ===== HERO ===== -->
  <header class="abc-hero">
    {%- if section.settings.poster != blank -%}
      <div class="abc-poster" style="background-image:url('{{ section.settings.poster | image_url: width: 1600 }}')"></div>
    {%- elsif collection.image -%}
      <div class="abc-poster" style="background-image:url('{{ collection.image | image_url: width: 1600 }}')"></div>
    {%- else -%}
      <div class="abc-ph"></div>
    {%- endif -%}
    <div class="abc-scrim"></div>
    <div class="abc-hero-in">
      {%- if section.settings.tag != blank -%}<span class="abc-tag">{{ section.settings.tag }}</span>{%- endif -%}
      <h1 class="abc-title">{{ section.settings.heading | default: collection.title | default: 'المجموعة' }}</h1>
      {%- assign sub = section.settings.subline | default: collection.description -%}
      {%- if sub != blank -%}<p class="abc-sub">{{ sub | strip_html | truncatewords: 26 }}</p>{%- endif -%}
      <div class="abc-under"></div>
    </div>
  </header>

  <!-- ===== PRODUCT GRID ===== -->
  {%- if collection.products.size > 0 -%}
    <div class="abc-grid">
      {%- for product in collection.products -%}
        <a class="abc-card" href="{{ product.url }}">
          <div class="abc-media">
            {%- if product.available == false -%}<span class="abc-soon">قريباً</span>{%- endif -%}
            {%- if product.featured_image -%}
              <img src="{{ product.featured_image | image_url: width: 700 }}" alt="{{ product.featured_image.alt | escape }}" loading="lazy" width="700" height="875">
            {%- else -%}
              <div class="abc-noimg">AB</div>
            {%- endif -%}
          </div>
          <div class="abc-info">
            <h3 class="abc-name">{{ product.title }}</h3>
            <div class="abc-price">
              {{ product.price | money }}
              {%- if product.compare_at_price > product.price -%}
                <span class="abc-cmp">{{ product.compare_at_price | money }}</span>
              {%- endif -%}
            </div>
          </div>
        </a>
      {%- endfor -%}
    </div>
  {%- else -%}
    <div class="abc-empty">
      <p>لا توجد منتجات في هذه المجموعة بعد. <b>قريباً.</b></p>
    </div>
  {%- endif -%}

</div>

<script>
(function(){
  var root = document.getElementById('ab-col-{{ section.id }}');
  if(!root) return;
  var cards = root.querySelectorAll('.abc-card');
  if(!('IntersectionObserver' in window)){ cards.forEach(function(c){c.classList.add('shown')}); return; }
  var io = new IntersectionObserver(function(entries){
    entries.forEach(function(e){
      if(e.isIntersecting){
        var i = Array.prototype.indexOf.call(cards, e.target);
        e.target.style.transitionDelay = (Math.min(i,5)*0.06)+'s';
        e.target.classList.add('shown');
        io.unobserve(e.target);
      }
    });
  },{threshold:.12, rootMargin:'0px 0px -8% 0px'});
  cards.forEach(function(c){ io.observe(c); });
})();
</script>

{% schema %}
{
  "name": "AB — المجموعة",
  "tag": "section",
  "class": "ab-collection-section",
  "settings": [
    { "type": "header", "content": "البوستر والنصوص" },
    { "type": "image_picker", "id": "poster", "label": "صورة البوستر (اتركها فارغة لاستخدام صورة المجموعة أو البليس هولدر)" },
    { "type": "text", "id": "heading", "label": "العنوان", "info": "اتركه فارغاً لاستخدام اسم المجموعة" },
    { "type": "textarea", "id": "subline", "label": "الوصف تحت العنوان", "info": "اتركه فارغاً لاستخدام وصف المجموعة" },
    { "type": "text", "id": "tag", "label": "شارة علوية (مثال: الدفعة الحالية)", "default": "الدفعة الحالية" },
    { "type": "header", "content": "اللون" },
    { "type": "color", "id": "accent", "label": "لون النيون", "default": "#AAFF00" }
  ],
  "presets": [
    { "name": "AB — المجموعة" }
  ]
}
{% endschema %}
