{%- comment -%}
  ════════════════════════════════════════════════
  AB — قسم المجموعة (بوستر فقط، Full-screen متحرك)
  يصلح للكولكشنات الثلاثة: travel / anime / couples
  الفرونت بيج = بوستر فقط، بدون عرض منتجات. زر "تسوّق المجموعة" يقود للمنتجين.
  التركيب: Online Store → Themes → Edit code → Sections → Add a new section
  سمّه: ab-collection  ثم الصق هذا واحفظ.
  - البوستر: يأخذ صورة المجموعة، وإن لم توجد يعرض بليس هولدر متحرك.
  ════════════════════════════════════════════════
{%- endcomment -%}

<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;500;600;700;900&display=swap" rel="stylesheet">

{%- assign accent = section.settings.accent | default: '#AAFF00' -%}

<style>
  #ab-col-{{ section.id }}{
    --ab-black:#080808; --ab-neon:{{ accent }}; --ab-silver:#9a9a9a;
    --ab-white:#F0F0F0; --ab-border:#222;
    background:var(--ab-black); color:var(--ab-white);
    font-family:'Cairo',sans-serif; direction:rtl;
    margin:0; padding:0; overflow:hidden;
  }
  #ab-col-{{ section.id }} *{box-sizing:border-box}

  #ab-col-{{ section.id }} .abc-hero{
    position:relative; min-height:100vh; display:flex;
    align-items:flex-end; overflow:hidden;
  }
  #ab-col-{{ section.id }} .abc-poster{
    position:absolute; inset:0; z-index:0;
    background-size:cover; background-position:center;
    animation:abc-kb 20s ease-in-out infinite alternate;
  }
  @keyframes abc-kb{from{transform:scale(1) translateY(0)}to{transform:scale(1.12) translateY(-2%)}}
  /* بليس هولدر متحرك إن لم توجد صورة */
  #ab-col-{{ section.id }} .abc-ph{
    position:absolute; inset:0; z-index:0;
    background:
      radial-gradient(circle at 30% 30%, rgba(170,255,0,.10), transparent 55%),
      repeating-linear-gradient(45deg,#0d0d0d 0 22px,#0a0a0a 22px 44px);
    animation:abc-kb 20s ease-in-out infinite alternate;
  }
  #ab-col-{{ section.id }} .abc-ph::after{
    content:'POSTER'; position:absolute; inset:0; display:flex;
    align-items:center; justify-content:center;
    font-size:clamp(2rem,8vw,5rem); font-weight:900; letter-spacing:.3em;
    color:rgba(255,255,255,.05);
  }
  #ab-col-{{ section.id }} .abc-scrim{
    position:absolute; inset:0; z-index:1;
    background:linear-gradient(to top,var(--ab-black) 3%,rgba(8,8,8,.55) 42%,rgba(8,8,8,.10) 100%);
  }
  #ab-col-{{ section.id }} .abc-in{
    position:relative; z-index:2; padding:0 7vw 9vh; width:100%;
  }
  #ab-col-{{ section.id }} .abc-tag{
    display:inline-block; font-size:.66rem; font-weight:700; letter-spacing:.3em;
    color:#000; background:var(--ab-neon); padding:.4rem 1rem; margin-bottom:1.2rem;
    clip-path:polygon(6px 0,100% 0,calc(100% - 6px) 100%,0 100%);
    animation:abc-up .9s .1s both;
  }
  #ab-col-{{ section.id }} .abc-title{
    font-size:clamp(3rem,13vw,7rem); font-weight:900; line-height:.92; margin:0;
    animation:abc-up 1s .2s both;
  }
  #ab-col-{{ section.id }} .abc-sub{
    font-size:clamp(1rem,3.6vw,1.5rem); font-weight:300; color:var(--ab-silver);
    max-width:600px; margin:1rem 0 0; animation:abc-up 1s .35s both;
  }
  #ab-col-{{ section.id }} .abc-cta{
    display:inline-block; margin-top:2rem; background:var(--ab-neon); color:#000;
    font-family:'Cairo'; font-size:.8rem; font-weight:700; letter-spacing:.2em;
    padding:1rem 2.6rem; text-decoration:none; transition:.2s;
    clip-path:polygon(8px 0,100% 0,calc(100% - 8px) 100%,0 100%);
    animation:abc-up 1s .55s both;
  }
  #ab-col-{{ section.id }} .abc-cta:hover{background:#fff; transform:translateY(-2px)}
  @keyframes abc-up{from{opacity:0;transform:translateY(26px)}to{opacity:1;transform:none}}

  /* مؤشر تمرير صغير */
  #ab-col-{{ section.id }} .abc-scroll{
    position:absolute; bottom:3vh; inset-inline-start:50%; transform:translateX(-50%);
    z-index:2; width:1px; height:42px; background:linear-gradient(var(--ab-neon),transparent);
    animation:abc-fade 2s ease-in-out infinite;
  }
  @keyframes abc-fade{0%,100%{opacity:.2}50%{opacity:.9}}
</style>

<div id="ab-col-{{ section.id }}">
  <header class="abc-hero">
    {%- if section.settings.poster != blank -%}
      <div class="abc-poster" style="background-image:url('{{ section.settings.poster | image_url: width: 1600 }}')"></div>
    {%- elsif collection.image -%}
      <div class="abc-poster" style="background-image:url('{{ collection.image | image_url: width: 1600 }}')"></div>
    {%- else -%}
      <div class="abc-ph"></div>
    {%- endif -%}
    <div class="abc-scrim"></div>
    <div class="abc-in">
      {%- if section.settings.tag != blank -%}<span class="abc-tag">{{ section.settings.tag }}</span>{%- endif -%}
      <h1 class="abc-title">{{ section.settings.heading | default: collection.title | default: 'المجموعة' }}</h1>
      {%- assign sub = section.settings.subline | default: collection.description -%}
      {%- if sub != blank -%}<p class="abc-sub">{{ sub | strip_html | truncatewords: 26 }}</p>{%- endif -%}
      {%- if section.settings.button_label != blank -%}
        {%- assign blink = section.settings.button_link | default: collection.url -%}
        <a class="abc-cta" href="{{ blink }}">{{ section.settings.button_label }}</a>
      {%- endif -%}
    </div>
    <div class="abc-scroll"></div>
  </header>
</div>

{% schema %}
{
  "name": "AB — المجموعة",
  "tag": "section",
  "class": "ab-collection-section",
  "settings": [
    { "type": "header", "content": "البوستر والنصوص" },
    { "type": "image_picker", "id": "poster", "label": "صورة البوستر (اتركها فارغة لاستخدام صورة المجموعة أو البليس هولدر)" },
    { "type": "text", "id": "heading", "label": "العنوان", "info": "اتركه فارغاً لاستخدام اسم المجموعة" },
    { "type": "textarea", "id": "subline", "label": "الوصف تحت العنوان", "info": "اتركه فارغاً لاستخدام وصف المجموعة" },
    { "type": "text", "id": "tag", "label": "شارة علوية", "default": "الدفعة الحالية" },
    { "type": "header", "content": "الزر" },
    { "type": "text", "id": "button_label", "label": "نص الزر", "default": "تسوّق المجموعة" },
    { "type": "url", "id": "button_link", "label": "رابط الزر", "info": "اتركه فارغاً ليقود لصفحة منتجات المجموعة" },
    { "type": "header", "content": "اللون" },
    { "type": "color", "id": "accent", "label": "لون النيون", "default": "#AAFF00" }
  ],
  "presets": [
    { "name": "AB — المجموعة" }
  ]
}
{% endschema %}
